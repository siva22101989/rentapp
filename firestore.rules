    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // ============== CUSTOMER VALIDATION ==============
    function isValidCustomer(data) {
      return data.name is string && data.name.size() > 0
          && data.phone is string && data.phone.size() > 0
          && data.address is string && data.address.size() > 0
          && (!('email' in data) || data.email is string)
          && (!('fatherName' in data) || data.fatherName is string)
          && (!('village' in data) || data.village is string);
    }
    
    match /customers/{customerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidCustomer(request.resource.data);
    }


    // ============== STORAGE RECORD VALIDATION ==============
   function isValidStorageRecord(data) {
        // --- Required on Create/Update ---
      return data.customerId is string
          && data.commodityDescription is string
          && data.location is string
          && data.bagsIn is number
          && data.storageStartDate is timestamp // Dates from client are converted
          && data.billingCycle is string
          && data.hamaliPayable is number
          && data.totalRentBilled is number
          && data.bagsOut is number
          && data.bagsStored is number
        // --- Optional Fields ---
          && (!('storageEndDate' in data) || data.storageEndDate == null || data.storageEndDate is timestamp)
          && (!('payments' in data) || data.payments is list)
          && (!('lorryTractorNo' in data) || data.lorryTractorNo is string)
          && (!('weight' in data) || data.weight is number)
          && (!('inflowType' in data) || data.inflowType in ['Direct', 'Plot'])
          && (!('plotBags' in data) || data.plotBags is number)
          && (!('loadBags' in data) || data.loadBags is number)
          && (!('khataAmount' in data) || data.khataAmount is number);
    }

    match /storageRecords/{recordId} {
      allow read: if isSignedIn();
      // Allow create and update with validation
      allow write: if isSignedIn() && isValidStorageRecord(request.resource.data);
    }

    // ============== EXPENSE VALIDATION ==============
    function isValidExpense(data) {
      return data.description is string && data.description.size() > 0
          && data.amount is number && data.amount > 0
          && data.category is string && data.category in ['Worker Salary', 'Petrol', 'Maintenance', 'Utilities', 'Hamali', 'Other']
          && data.date is timestamp;
    }

    match /expenses/{expenseId} {
