rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profile data
    match /users/{userId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }

    // Business data collections
    match /customers/{docId} { allow get, write: if request.auth != null; }
    match /customers { allow list: if request.auth != null; }

    match /commodities/{docId} { allow get, write: if request.auth != null; }
    match /commodities { allow list: if request.auth != null; }

    match /lots/{docId} { allow get, write: if request.auth != null; }
    match /lots { allow list: if request.auth != null; }

    match /storageRecords/{docId} { allow get, write: if request.auth != null; }
    match /storageRecords { allow list: if request.auth != null; }

    match /expenses/{docId} { allow get, write: if request.auth != null; }
    match /expenses { allow list: if request.auth != null; }

    match /borrowings/{docId} { allow get, write: if request.auth != null; }
    match /borrowings { allow list: if request.auth != null; }

    match /lendings/{docId} { allow get, write: if request.auth != null; }
    match /lendings { allow list: if request.auth != null; }

    match /otherIncomes/{docId} { allow get, write: if request.auth != null; }
    match /otherIncomes { allow list: if request.auth != null; }

    match /unloadingRecords/{docId} { allow get, write: if request.auth != null; }
    match /unloadingRecords { allow list: if request.auth != null; }

    match /dryingRecords/{docId} { allow get, write: if request.auth != null; }
    match /dryingRecords { allow list: if request.auth != null; }
    
    // Settings collections
    match /settings/{docId} { allow get, write: if request.auth != null; }
    match /settings { allow list: if request.auth != null; }
    
    // Super-admin only collection
    match /managedWarehouses/{docId} { allow get, write: if request.auth != null; }
    match /managedWarehouses { allow list: if request.auth != null; }
  }
}
