
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth.token.admin == true;
    }

    // Default read access for any signed-in user
    match /{document=**} {
      allow read: if isSignedIn();
    }

    // Customers: Admins can write.
    match /customers/{customerId} {
      allow write: if isAdmin();
    }

    // Storage Records: Admins can write.
    match /storageRecords/{recordId} {
      allow write: if isAdmin();
    }
    
    // Expenses: Admins can write.
    match /expenses/{expenseId} {
      allow write: if isAdmin();
    }
  }
}
