
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // For development: Hardcode a specific user email as admin.
      // For production, this should be replaced with custom claims:
      // return request.auth.token.admin == true;
      return request.auth.token.email == 'nikhilpnkr@gmail.com';
    }

    // Default read access for any signed-in user
    match /{document=**} {
      allow read: if isSignedIn();
    }

    // Allow any signed-in user to perform all write operations.
    // This is a simpler security model for trusted internal users.
    match /customers/{customerId} {
      allow update, delete: if isSignedIn();
    }
    match /customers {
        allow create: if isSignedIn();
    }

    match /storageRecords/{recordId} {
      allow update, delete: if isSignedIn();
    }
    match /storageRecords {
        allow create: if isSignedIn();
    }
    
    match /expenses/{expenseId} {
      allow update, delete: if isSignedIn();
    }
    match /expenses {
        allow create: if isSignedIn();
    }
  }
}
