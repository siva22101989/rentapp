
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'super-admin';
    }

    function isWarehouseMember(warehouseId) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().warehouseId == warehouseId;
    }

    match /managedWarehouses/{warehouseId} {
      allow read, write: if isSuperAdmin();
    }
    
    match /users/{userId} {
      // Users can read/update their own document.
      allow read, update: if isSignedIn() && request.auth.uid == userId;

      // New users can create their own doc during migration/first sign-in.
      // An owner/super-admin can create docs for others (invites).
      allow create: if (isSignedIn() && request.auth.uid == userId) || 
                     (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
                       (getUserData().role == 'owner' || getUserData().role == 'super-admin'));
      
      // An owner/super-admin can delete user docs.
      // A user can delete the old auto-id document during migration. This is hard to secure
      // perfectly without a backend, so we allow any signed-in user to delete for now
      // to make the migration process work.
      allow delete: if isSignedIn();
    }

    // Main rule for all data within a warehouse.
    match /managedWarehouses/{warehouseId}/{document=**} {
      allow read, write: if isWarehouseMember(warehouseId);
    }
  }
}
