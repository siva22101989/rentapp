
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Default-deny all access
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow signed-in users to manage their own user document
    match /users/{userId} {
      allow read, update, delete: if isSignedIn() && request.auth.uid == userId;
      // Allow creation for new sign-ups
      allow create: if isSignedIn();
    }
    
    // Allow any authenticated user to read and write to the data collections.
    // This is a typical setup for a single-warehouse application where all
    // logged-in users are trusted team members.
    match /customers/{customerId} {
      allow read, write: if isSignedIn();
    }
    match /commodities/{commodityId} {
      allow read, write: if isSignedIn();
    }
    match /lots/{lotId} {
      allow read, write: if isSignedIn();
    }
    match /storageRecords/{recordId} {
      allow read, write: if isSignedIn();
    }
    match /expenses/{expenseId} {
      allow read, write: if isSignedIn();
    }
    match /borrowings/{borrowingId} {
      allow read, write: if isSignedIn();
    }
    match /lendings/{lendingId} {
      allow read, write: if isSignedIn();
    }
    match /otherIncomes/{incomeId} {
      allow read, write: if isSignedIn();
    }
    match /unloadingRecords/{unloadingId} {
      allow read, write: if isSignedIn();
    }
    match /dryingRecords/{dryingId} {
      allow read, write: if isSignedIn();
    }
    match /settings/{settingId} {
       allow read, write: if isSignedIn();
    }
  }
}
