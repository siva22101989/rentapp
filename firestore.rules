
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isSuperAdmin() {
      return isSignedIn() && getUserData().role == 'super-admin';
    }

    function isMemberOfWarehouse(warehouseId) {
      return isSignedIn() && getUserData().warehouseId == warehouseId;
    }
    
    // Default-deny all access
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow create: if isSignedIn();
      allow read, update: if (isSignedIn() && request.auth.uid == userId) || isSuperAdmin();
      // Allow any authenticated user to list users to find their record during login.
      allow list: if isSignedIn();
      allow delete: if isSuperAdmin();
    }

    // Super-admin can manage the list of warehouses
    match /managedWarehouses/{warehouseId} {
      allow read, list, write: if isSuperAdmin();
    }
    
    // Rules for data within a specific warehouse
    match /managedWarehouses/{warehouseId}/{document=**} {
      allow read, write: if isSuperAdmin() || isMemberOfWarehouse(warehouseId);
    }
  }
}
