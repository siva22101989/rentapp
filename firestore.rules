
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if a user is a super-admin
    function isSuperAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super-admin';
    }

    // Helper function to check if the user belongs to the requested warehouse
    function isWarehouseMember(warehouseId) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.warehouseId == warehouseId;
    }

    // Super-admin can manage the list of warehouses.
    match /managedWarehouses/{warehouseId} {
      allow read, write: if isSuperAdmin();
    }
    
    // Allow signed-in users to read from the users collection to find their own profile.
    // Writes are restricted to the user themselves or a super-admin (for creation).
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if request.auth.uid == userId;
      allow create: if isSignedIn(); // Allows for initial user creation during sign-up
    }

    // All documents within a warehouse's subcollection can only be accessed
    // by members of that warehouse.
    match /managedWarehouses/{warehouseId}/{document=**} {
      allow read, write: if isWarehouseMember(warehouseId);
    }
  }
}
