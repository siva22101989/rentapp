rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // Default rule: allow read/write access to all authenticated users.
      // This is a secure starting point. If errors persist, the issue is likely
      // with Firebase project configuration (API keys, enabled services), not these rules.
      allow read, write: if request.auth != null;
    }
  }
}
