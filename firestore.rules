    // Allow unauthenticated reads on the users collection FOR LOGIN CHECK ONLY
    match /users/{userId} {
      allow list: if !exists(/databases/$(database)/documents/users/$(request.auth.uid));
      allow read, write: if request.auth.uid == userId;
    }

