rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profile data
    match /users/{userId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }

    // Business data collections
    match /customers/{doc} { allow read, write: if request.auth != null; }
    match /commodities/{doc} { allow read, write: if request.auth != null; }
    match /lots/{doc} { allow read, write: if request.auth != null; }
    match /storageRecords/{doc} { allow read, write: if request.auth != null; }
    match /expenses/{doc} { allow read, write: if request.auth != null; }
    match /borrowings/{doc} { allow read, write: if request.auth != null; }
    match /lendings/{doc} { allow read, write: if request.auth != null; }
    match /otherIncomes/{doc} { allow read, write: if request.auth != null; }
    match /unloadingRecords/{doc} { allow read, write: if request.auth != null; }
    match /dryingRecords/{doc} { allow read, write: if request.auth != null; }
    
    // Settings collections
    match /settings/{doc} { allow read, write: if request.auth != null; }
    
    // Super-admin only collection
    match /managedWarehouses/{doc} { allow read, write: if request.auth != null; }
  }
}
