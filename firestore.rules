
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Allow any signed-in user to perform all read and write operations.
    // This is a simple security model suitable for internal applications
    // where all users are trusted.
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
