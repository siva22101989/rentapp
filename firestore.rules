    // Grant access to all other collections
    match /customers/{docId}           { allow get, write: if isAuthenticated(); }
    match /customers                   { allow list: if isAuthenticated(); }
    
    match /commodities/{docId}         { allow get, write: if isAuthenticated(); }
    match /commodities                 { allow list: if isAuthenticated(); }
    
    match /lots/{docId}                { allow get, write: if isAuthenticated(); }
    match /lots                        { allow list: if isAuthenticated(); }
    
    match /storageRecords/{docId}      { allow get, write: if isAuthenticated(); }
    match /storageRecords              { allow list: if isAuthenticated(); }
    
    match /expenses/{docId}            { allow get, write: if isAuthenticated(); }
    match /expenses                    { allow list: if isAuthenticated(); }
    
    match /borrowings/{docId}          { allow get, write: if isAuthenticated(); }
    match /borrowings                  { allow list: if isAuthenticated(); }
    
    match /lendings/{docId}            { allow get, write: if isAuthenticated(); }
    match /lendings                    { allow list: if isAuthenticated(); }
    
    match /otherIncomes/{docId}        { allow get, write: if isAuthenticated(); }
    match /otherIncomes                { allow list: if isAuthenticated(); }
    
    match /unloadingRecords/{docId}    { allow get, write: if isAuthenticated(); }
