
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // WARNING: These rules are completely open and are for testing purposes only.
    // They allow anyone to read, write, and delete data in your database.
    // Revert to secure rules before deploying to production.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
