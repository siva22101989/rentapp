rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isCreating() {
      return resource == null;
    }

    function isUpdating() {
      return resource != null;
    }

    // Customer documents can be read and written by any authenticated user,
    // as long as the data is valid.
    match /customers/{customerId} {
      allow read, write: if isSignedIn() &&
                      (isCreating() || isUpdating()) &&
                      request.resource.data.name is string &&
                      request.resource.data.phone is string &&
                      request.resource.data.address is string &&
                      request.resource.data.fatherName is string &&
                      request.resource.data.village is string &&
                      request.resource.data.email is string;

    }

    // Storage records can be read and written by any authenticated user,
    // as long as the data is valid.
    match /storageRecords/{recordId} {
      allow read, write: if isSignedIn() &&
                      (isCreating() || isUpdating()) &&
                      request.resource.data.customerId is string &&
                      request.resource.data.commodityDescription is string &&
                      request.resource.data.location is string &&
                      request.resource.data.bagsStored is number &&
                      request.resource.data.storageStartDate is timestamp &&
                      request.resource.data.billingCycle is string;
    }

    // Expenses can be read and written by any authenticated user,
    // as long as the data is valid.
    match /expenses/{expenseId} {
        allow read, write: if isSignedIn() &&
                        (isCreating() || isUpdating()) &&
                        request.resource.data.description is string &&
                        request.resource.data.amount is number &&
                        request.resource.data.category is string &&
                        request.resource.data.date is timestamp;
    }
  }
}
